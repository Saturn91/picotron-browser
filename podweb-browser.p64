--[[pod_format="raw",created="2026-04-16 15:34:19",modified="2026-04-16 15:55:32",revision=6]]
-- Podweb Browser v0.1

gui = create_gui()

-- ============================
-- Constants
-- ============================
local W, H     = 480, 270
local BAR_H    = 16
local PAD_X    = 6
local CONT_W   = W - PAD_X * 2
local LINE_H   = 8
local CHAR_W   = 4   -- approx px per character (used for decorative underline only)

local MY_ID      = "48932"
local DOMAINS_FILE = "podnet://" .. MY_ID .. "/domains.lookup"

-- measure actual pixel width of a string using print() off the top of the screen
function text_width(s)
  return print(s, 0, -20)
end

-- ============================
-- State
-- ============================
local url      = "podnet://48932/index.podweb"
local items    = {}  -- laid-out render items: {tag, text, y}
local total_h  = 0
local scroll_y = 0
local prev_mb  = 0
local url_bar  = nil  -- set in _init()
local domains  = {}   -- domain -> user_id, loaded from DOMAINS_FILE

local BTN_R = { x=4, y=2, w=36, h=12, label="Reload" }

-- ============================
-- Parser
-- ============================
function parse(src)
  local nodes, lines, meta = {}, {}, {}
  for l in string.gmatch(src.."\n", "([^\n]*)\n") do
    add(lines, l)
  end

  local i = 1
  while i <= #lines do
    local l = lines[i]

    -- parse [meta-]...[-meta] into key/value table
    if string.match(l, "^%[meta%-%]") then
      i += 1
      while i <= #lines and not string.match(lines[i], "^%[%-meta%]") do
        local key, val = string.match(lines[i], "^(%w+):%s*(.+)")
        if key then meta[key] = val end
        i += 1
      end
      i += 1  -- skip [-meta]

    -- block tag: [tag-] ... [-tag]
    elseif string.match(l, "^%[[%a%d]+%-%]") then
      local tag   = string.match(l, "^%[([%a%d]+)%-%]")
      local close = "[-"..tag.."]"
      local parts = {}
      i += 1
      while i <= #lines and lines[i] ~= close do
        add(parts, lines[i])
        i += 1
      end
      -- code blocks preserve line structure; others join for word wrap
      local text = ""
      if tag == "code" then
        for j, p in ipairs(parts) do
          text = j == 1 and p or (text.."\n"..p)
        end
      else
        for _, p in ipairs(parts) do
          if p ~= "" then
            text = text == "" and p or (text.." "..p)
          end
        end
      end
      add(nodes, { tag=tag, text=text })
      i += 1  -- skip closing tag

    -- link tag: [link user=X file=Y] display text
    elseif string.match(l, "^%[link") then
      local attrs = string.match(l, "^%[link([^%]]*)%]")
      local text  = string.match(l, "^%[link[^%]]*%] (.+)")
      if text then
        add(nodes, {
          tag  = "link",
          text = text,
          user = attrs and string.match(attrs, "user=(%d+)"),
          file = attrs and string.match(attrs, "file=(%S+)"),
        })
      end
      i += 1

    -- inline tag: [tag] text
    elseif string.match(l, "^%[[%a%d]+%] .+") then
      local tag  = string.match(l, "^%[([%a%d]+)%]")
      local text = string.match(l, "^%[[%a%d]+%] (.+)")
      add(nodes, { tag=tag, text=text })
      i += 1

    else
      i += 1
    end
  end

  return nodes, meta
end

-- ============================
-- Word wrap
-- ============================
function word_wrap(text, max_w)
  local out, cur, words = {}, "", {}
  for w in string.gmatch(text, "%S+") do add(words, w) end
  for _, w in ipairs(words) do
    local candidate = cur == "" and w or (cur.." "..w)
    if text_width(candidate) <= max_w then
      cur = candidate
    else
      if cur ~= "" then add(out, cur) end
      cur = w
    end
  end
  if cur ~= "" then add(out, cur) end
  if #out == 0 then add(out, "") end
  return out
end

-- ============================
-- Layout
-- ============================
function do_layout(nodes)
  local out, y = {}, 4
  for idx, n in ipairs(nodes) do
    if n.tag == "h1" then
      if idx > 1 then y += 8 end
      add(out, { tag="h1", text=n.text, y=y })
      y += LINE_H + 4
    elseif n.tag == "h2" then
      if idx > 1 then y += 6 end
      add(out, { tag="h2", text=n.text, y=y })
      y += LINE_H + 3
    elseif n.tag == "p" then
      for _, line in ipairs(word_wrap(n.text, CONT_W)) do
        add(out, { tag="p", text=line, y=y })
        y += LINE_H
      end
      y += 4
    elseif n.tag == "link" then
      y += 2
      add(out, { tag="link", text=n.text, user=n.user, file=n.file, y=y })
      y += LINE_H + 2
    elseif n.tag == "code" then
      local code_lines = {}
      for l in string.gmatch(n.text.."\n", "([^\n]*)\n") do
        add(code_lines, l)
      end
      local block_h = #code_lines * LINE_H + 6
      y += 2
      add(out, { tag="code", lines=code_lines, y=y, h=block_h })
      y += block_h + 4
    end
  end
  return out, y
end

-- ============================
-- Domain lookup
-- ============================
function load_domains()
  local src = fetch(DOMAINS_FILE)
  if src and src ~= "" then
    domains = unpod(src) or {}
  end
end

function save_domains()
  store(DOMAINS_FILE, pod(domains))
end

function resolve_url(input)
  if string.match(input, "^podnet://") then return input end
  -- accept "domain/file" or just "domain" (defaults to index.podweb)
  local domain, file = string.match(input, "^([^/]+)/(.+)")
  if not domain then
    domain = input
    file   = "index.podweb"
  end
  local user_id = domains[domain]
  if user_id then
    return "podnet://" .. user_id .. "/" .. file
  end
  return nil  -- unknown domain
end

-- ============================
-- Fetch + parse + layout
-- ============================
function do_fetch()
  scroll_y = 0
  items    = {}
  local src = fetch(url)
  if src and src ~= "" then
    local nodes, meta = parse(src)
    items, total_h = do_layout(nodes)
    -- register domain in local lookup if new
    local display = url
    if meta.domain then
      local user_id = string.match(url, "podnet://(%d+)/")
      if user_id and not domains[meta.domain] then
        domains[meta.domain] = user_id
        save_domains()
      end
      local file = string.match(url, "podnet://%d+/(.+)")
      display = meta.domain .. "/" .. (file or "")
    end
    if url_bar and url_bar.set_text then url_bar:set_text(display) end
  else
    if url_bar and url_bar.set_text then url_bar:set_text(url) end
  end
end

-- ============================
-- Navigation helpers
-- ============================
function link_hover(item)
  local mx, my = mouse()
  local iy = BAR_H + 1 + item.y - scroll_y
  return mx >= PAD_X and mx < PAD_X + text_width(item.text)
     and my >= iy    and my < iy + LINE_H
end

function navigate(item)
  local cur_user = string.match(url, "podnet://(%d+)/")
  local user_id  = item.user or cur_user
  local file     = item.file or "index.podweb"
  url = "podnet://"..user_id.."/"..file
  do_fetch()
end

-- ============================
-- Button helpers
-- ============================
function btn_over(b)
  local mx, my = mouse()
  return mx >= b.x and mx < b.x+b.w
     and my >= b.y and my < b.y+b.h
end

function draw_btn(b)
  local hov = btn_over(b)
  rectfill(b.x, b.y, b.x+b.w-1, b.y+b.h-1, hov and 6 or 2)
  rect    (b.x, b.y, b.x+b.w-1, b.y+b.h-1, 5)
  local tx = b.x + flr((b.w - #b.label*4) / 2)
  local ty = b.y + flr((b.h - 5) / 2)
  print(b.label, tx, ty, hov and 0 or 6)
end

-- ============================
-- Init
-- ============================
function _init()
  window({ width=W, height=H, title="Podweb Browser" })
  load_domains()

  url_bar = gui:attach_text_editor{
    x      = BTN_R.x + BTN_R.w + 4,
    y      = 2,
    width  = W - BTN_R.x - BTN_R.w - 8,
    height = BAR_H - 4,
    key_callback = {
      ["enter"] = function(self, k)
        local input = self:get_text()[1]
        if input and input ~= "" then
          url = resolve_url(input) or input
          do_fetch()
        end
        return nil  -- don't insert a newline
      end
    }
  }
  if url_bar.set_text then url_bar:set_text(url) end

  do_fetch()
end

-- ============================
-- Update
-- ============================
function _update()
  local _, _, mb = mouse()

  -- scroll with arrow keys (clamped)
  local max_scroll = max(0, total_h - (H - BAR_H))
  if btn(2) then scroll_y = max(0, scroll_y - 3) end
  if btn(3) then scroll_y = min(max_scroll, scroll_y + 3) end

  -- click release: check reload button then links
  if (prev_mb & 1) == 1 and (mb & 1) == 0 then
    if btn_over(BTN_R) then
      do_fetch()
    else
      for _, item in ipairs(items) do
        if item.tag == "link" and link_hover(item) then
          navigate(item)
          break
        end
      end
    end
  end
  prev_mb = mb
  gui:update_all()
end

-- ============================
-- Draw
-- ============================
function _draw()
  cls(1)

  -- address bar (url_bar widget drawn automatically by gui)
  rectfill(0, 0, W-1, BAR_H-1, 0)
  draw_btn(BTN_R)
  line(0, BAR_H, W-1, BAR_H, 5)

  -- content area (clipped)
  clip(0, BAR_H+1, W, H-BAR_H-1)
  for _, item in ipairs(items) do
    local y = BAR_H + 1 + item.y - scroll_y
    local item_h = item.h or LINE_H
    if y + item_h > BAR_H and y < H + LINE_H then
      if item.tag == "h1" then
        print(item.text, PAD_X, y, 7)
        line(PAD_X, y+LINE_H-1, PAD_X+#item.text*CHAR_W+2, y+LINE_H-1, 5)
      elseif item.tag == "h2" then
        print(item.text, PAD_X, y, 12)
      elseif item.tag == "link" then
        local col = link_hover(item) and 7 or 12
        print(item.text, PAD_X, y, col)
        line(PAD_X, y+LINE_H-1, PAD_X+text_width(item.text)-1, y+LINE_H-1, col)
      elseif item.tag == "code" then
        rectfill(PAD_X-2, y,   PAD_X+CONT_W+2, y+item.h-1, 0)
        rect    (PAD_X-2, y,   PAD_X+CONT_W+2, y+item.h-1, 5)
        for li, l in ipairs(item.lines) do
          print(l, PAD_X+2, y+3+(li-1)*LINE_H, 11)
        end
      else
        print(item.text, PAD_X, y, 6)
      end
    end
  end
  clip()
  
  gui:draw_all()
end

